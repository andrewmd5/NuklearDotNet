<Project>
  <!--
    Build native Nuklear2 via CMake and register it as a CopyToOutput item.
    All properties are evaluated inside the target body so that SDK-defined
    values (IntermediateOutputPath, RuntimeIdentifier, etc.) are available.
    BeforeTargets="AssignTargetPaths" ensures the None item is visible for
    transitive copy when consuming projects resolve this project's output items.

    Architecture priority (Windows):
      PlatformTarget / RuntimeIdentifier (set via -p:Platform=x64, csproj, etc.),
      then MSBuild host process architecture as fallback.
  -->
  <Target Name="BuildNativeNuklear" BeforeTargets="AssignTargetPaths;Build">
    <PropertyGroup>
      <NuklearNativeDir>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)..\..\..\native'))</NuklearNativeDir>
      <NuklearNativeBuildDir>$(IntermediateOutputPath)native-build</NuklearNativeBuildDir>
    </PropertyGroup>

    <!-- Platform-specific native library names and paths -->
    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
      <NuklearNativeLib>Nuklear2.dll</NuklearNativeLib>
      <NuklearNativeBuildOutput>$(NuklearNativeBuildDir)\Release\$(NuklearNativeLib)</NuklearNativeBuildOutput>
    </PropertyGroup>
    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
      <NuklearNativeLib>libNuklear2.so</NuklearNativeLib>
      <NuklearNativeBuildOutput>$(NuklearNativeBuildDir)/$(NuklearNativeLib)</NuklearNativeBuildOutput>
    </PropertyGroup>
    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
      <NuklearNativeLib>libNuklear2.dylib</NuklearNativeLib>
      <NuklearNativeBuildOutput>$(NuklearNativeBuildDir)/$(NuklearNativeLib)</NuklearNativeBuildOutput>
    </PropertyGroup>

    <!-- CMake configure flags (Windows) -->
    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
      <!-- PlatformTarget (propagates via -p:Platform=x64) or RuntimeIdentifier -->
      <NuklearCMakeArch Condition="'$(PlatformTarget)' == 'x64' OR '$(RuntimeIdentifier)' == 'win-x64'">x64</NuklearCMakeArch>
      <NuklearCMakeArch Condition="'$(PlatformTarget)' == 'ARM64' OR '$(RuntimeIdentifier)' == 'win-arm64'">ARM64</NuklearCMakeArch>
      <!-- Fallback: match the MSBuild host process architecture -->
      <NuklearCMakeArch Condition="'$(NuklearCMakeArch)' == '' AND '$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture)' == 'X64'">x64</NuklearCMakeArch>
      <NuklearCMakeArch Condition="'$(NuklearCMakeArch)' == '' AND '$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture)' == 'Arm64'">ARM64</NuklearCMakeArch>
      <NuklearCMakeArchFlag Condition="'$(NuklearCMakeArch)' != ''">-A $(NuklearCMakeArch)</NuklearCMakeArchFlag>
      <NuklearCMakeConfigureExtra>$(NuklearCMakeArchFlag)</NuklearCMakeConfigureExtra>
      <NuklearCMakeBuildExtra>--config Release</NuklearCMakeBuildExtra>
    </PropertyGroup>
    <!-- CMake configure flags (Linux/macOS) -->
    <PropertyGroup Condition="!$([MSBuild]::IsOSPlatform('Windows'))">
      <NuklearCMakeConfigureExtra>-DCMAKE_BUILD_TYPE=Release</NuklearCMakeConfigureExtra>
      <NuklearCMakeBuildExtra></NuklearCMakeBuildExtra>
    </PropertyGroup>

    <Message Text="Building native Nuklear2 via CMake (arch: $(NuklearCMakeArch))..." Importance="High"
             Condition="!Exists('$(NuklearNativeBuildOutput)')" />
    <Exec Condition="!Exists('$(NuklearNativeBuildOutput)')"
          Command="cmake -S &quot;$(NuklearNativeDir)&quot; -B &quot;$(NuklearNativeBuildDir)&quot; $(NuklearCMakeConfigureExtra)" />
    <Exec Condition="!Exists('$(NuklearNativeBuildOutput)')"
          Command="cmake --build &quot;$(NuklearNativeBuildDir)&quot; $(NuklearCMakeBuildExtra)" />

    <!-- Register the native DLL so it flows transitively to consuming projects -->
    <ItemGroup>
      <None Include="$(NuklearNativeBuildOutput)" Condition="Exists('$(NuklearNativeBuildOutput)')">
        <Link>$(NuklearNativeLib)</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
    </ItemGroup>
  </Target>

  <!-- AOT static linking -->
  <Target Name="ResolveNuklearAotPaths" BeforeTargets="ResolveAssemblyReferences"
          Condition="'$(PublishAot)' == 'true'">
    <PropertyGroup>
      <NuklearNativeBuildDir>$(IntermediateOutputPath)native-build</NuklearNativeBuildDir>
      <NuklearStaticLib Condition="$([MSBuild]::IsOSPlatform('Windows'))">$(NuklearNativeBuildDir)\Release\Nuklear2_static.lib</NuklearStaticLib>
      <NuklearStaticLib Condition="!$([MSBuild]::IsOSPlatform('Windows'))">$(NuklearNativeBuildDir)/libNuklear2_static.a</NuklearStaticLib>
    </PropertyGroup>
    <ItemGroup>
      <DirectPInvoke Include="Nuklear2" />
      <NativeLibrary Include="$(NuklearStaticLib)" />
    </ItemGroup>
  </Target>

  <!-- Ensure native build happens before AOT publish -->
  <Target Name="BuildNativeNuklearForAot" BeforeTargets="Publish"
          DependsOnTargets="BuildNativeNuklear"
          Condition="'$(PublishAot)' == 'true'" />
</Project>
